# Production Environment Variables
EXPO_PUBLIC_ENVIRONMENT=production
EXPO_PUBLIC_API_VERSION=v1
EXPO_PUBLIC_ENABLE_ANALYTICS=true

# Optional: Claude API for AI Triage (user configurable)
# EXPO_PUBLIC_CLAUDE_API_KEY=sk-ant-...

# Optional: Google APIs
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...
# EXPO_PUBLIC_VISION_API_URL=https://vision.googleapis.com/v1/images:annotate

# Feature Flags
EXPO_PUBLIC_ENABLE_VOICE_SOS=true
EXPO_PUBLIC_ENABLE_HOSPITAL_ROUTING=true
EXPO_PUBLIC_ENABLE_INCIDENT_REPORTS=true
EXPO_PUBLIC_ENABLE_OFFLINE_MODE=true

# Error Tracking
EXPO_PUBLIC_SENTRY_DSN=
